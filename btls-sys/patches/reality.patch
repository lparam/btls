diff --git a/ssl/ssl_key_share.cc b/ssl/ssl_key_share.cc
index d155b5527..8757492ad 100644
--- a/ssl/ssl_key_share.cc
+++ b/ssl/ssl_key_share.cc
@@ -143,9 +143,22 @@ class X25519KeyShare : public SSLKeyShare {
 
   uint16_t GroupID() const override { return SSL_GROUP_X25519; }
 
+  bool has_fixed_key_ = false;
+
+  bool SetFixedPrivateKey(bssl::Span<const uint8_t> key) override {
+    if (key.size() != 32) return false;
+    OPENSSL_memcpy(private_key_, key.data(), 32);
+    has_fixed_key_ = true;
+    return true;
+  }
+
   bool Generate(CBB *out) override {
     uint8_t public_key[32];
-    X25519_keypair(public_key, private_key_);
+    if (has_fixed_key_) {
+      X25519_public_from_private(public_key, private_key_);
+    } else {
+      X25519_keypair(public_key, private_key_);
+    }
     return !!CBB_add_bytes(out, public_key, sizeof(public_key));
   }
 
