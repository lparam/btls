+void SSL_set_fixed_ecdh_private_key(SSL *ssl, const uint8_t *key, size_t key_len) {
+  if (!ssl || !ssl->config || key_len != 32) {
+    return;
+  }
+  OPENSSL_memcpy(ssl->config->fixed_x25519_key, key, 32);
+  ssl->config->has_fixed_x25519_key = true;
+}
